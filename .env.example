# ── Nexus gateway ────────────────────────────────────────────────
# Shared secret required in the X-Nexus-Key header for /v1/route.
# If unset, auth is DISABLED (dev mode only — never deploy without it).
NEXUS_API_KEY=change-me

# ── Downstream service base URLs ─────────────────────────────────
# Sayra / n8n / agents defaults match docker-compose service names.
SAYRA_URL=http://sayra:7860
N8N_URL=http://n8n:5678
# Base URL for triggering n8n webhooks (usually N8N_URL + /webhook)
N8N_WEBHOOK_BASE=http://n8n:5678/webhook
AGENTS_URL=http://agents:8090

# Routely (Saas) is a SEPARATE repo — never vendored in this project.
# Point this at your Routely deploy or a local Saas process outside Nexus.
ROUTELY_URL=http://localhost:8000

# ── Downstream auth keys ─────────────────────────────────────────
ROUTELY_API_KEY=
AGENTS_API_KEY=

# ── Behaviour tuning ─────────────────────────────────────────────
# Per-request forward timeout in seconds
NEXUS_FORWARD_TIMEOUT=30
# Health check timeout per service in seconds
NEXUS_HEALTH_TIMEOUT=5
